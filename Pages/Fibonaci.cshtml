@page
@model Calculo_de_salario.Pages.Fibonaci
@{
    ViewData["Title"] = "Fibonacci";
}
<div class="calculadora-card themeBlack">
        <h2>Sequencia Fibonaci</h2>
</div>
<section class="themeBlack layoutColumn">
    Digite um numero e descubra se ele faz parte da sequencia Fibonaci
    <div  class="layoutRow">
            <div  id="displaySequence">
            <form  class="layoutRow" method="post">
                <div>
                    Digite um numero da sequencia Fibonaci
                    <input type="number" asp-for="numberCompareFibonaci">
                    
                </div>
                <div>
                    Digite quantos numeros da sequencia fibonaci quer ver
                <input type="number" asp-for="limitFibonaci">
                </div>
                <button type="submit" >Verificar</button>
            </form>
         </div>
      
    </div>
    <div>
        <div class="valor-final">
        <p style="color: rgb(255, 255, 255);"> @Model.message</p>
    </div>
    <div>
        <div class="valor-final">
        <p style="max-width: 700px;" >Fibonaci @Model.sequence</p>
    </div>
    </div>
</section>


