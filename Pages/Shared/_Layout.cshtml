<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Calculo_de_salario</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Calculo_de_salario.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
    <section class="layout">
        <a  class="card" asp-page="SalaryCalculator">Calcular Salario</a>
        <a class="card" asp-page="Fibonaci">Fibonaci</a>
        <a class="card" asp-page="NumberSequenci">Number Sequence</a>
</section>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
            
        </main>
    </div>

    

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

<style>
    
:root {
  /* Declaração das variáveis */
  --cor-fundo: #0c0c0c;
   --cor-fundo2:#505050;
  --cor-primaria: wheat;
  --espacamento: 10px;
}
html {
  font-size: 14px;
}



.btn:focus, .btn:active:focus, .btn-link.nav-link:focus, .form-control:focus, .form-check-input:focus {
  box-shadow: 0 0 0 0.1rem white, 0 0 0 0.25rem #258cfb;
}

html {
  position: relative;
  min-height: 100%;
}

body {
  margin-bottom: 60px;
}

.form-floating > .form-control-plaintext::placeholder, .form-floating > .form-control::placeholder {
  color: var(--bs-secondary-color);
  text-align: end;
}

.form-floating > .form-control-plaintext:focus::placeholder, .form-floating > .form-control:focus::placeholder {
  text-align: start;
}
.container{
  display: flex;
  flex-direction: column;
  align-content: center;
  align-items: center;
}

.layout{
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: row;
        width: 100%;
    }
    .card{
      transition: 1s;
        background-color: rgb(117, 117, 117);
        border: none;
        border-radius: 100px;
        display: flex;
        align-items: center;
        align-content: center;
        justify-content: center;
        padding: 20px;
        width: 400px;
        margin: 10px;
    color: white;

    }

      .card:hover{
        transition: 1s;
        width: 460px;

    }
    a{text-decoration: none;
    display: block;
    }


    button{
      border: none;
      padding: 10px 20px;
      border-radius: 100px;
    }
    form{
      display: flex;
      flex-direction: column;
    }

 



.valor-final {
  font-size: 1.25rem;
  font-weight: bold;
  color: #2c3e50;
}

.box{
  padding: 5px;
  border-radius: 10px;
  margin: 10px;
}

.themeBlack {
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: var(--cor-fundo);
  color: var(--cor-primaria);
  padding: 20px; 
  border-radius: 15px;
  transition: all 0.3s ease; 
  margin: 3px;
}

.layoutRow{
   display: flex;
   flex-direction: row;
}

.layoutColumn{
   display: flex;
   flex-direction: column;
   align-items: center;
   justify-content: center;
}

.themeBlack * {
  color:var(--cor-primaria);
  border-color: var(--cor-primaria);
}

.themeBlack div {
  background-color: var(--cor-fundo2);
  padding: 10px;
  border-radius: 10px;
  margin: 2px;
  align-items: center;
  justify-content: center;
}

.themeBlack button {
  background-color: var(--cor-primaria);
  padding: 10px;
  color: black;
  width: 50%;
  max-width: 200px;
  max-height: 50px;
  border-radius: 10px;
  margin: 3px;
}
.themeBlack input {
  border: none;
      background-color: #dbdbdb;
      padding: 5px 10px;
      border-radius: 100px;
      margin: 3px;
       display: flex;
  flex-direction: column;
  gap: 15px;
  margin: 1px;
  color: black;
}

.themeWhite{
  background-color: white;
  color: black;
}


.errorSpam{
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 0, 0, 0.683);
  border-radius: 100px;
  font-size: 20px;
  color: white;
}

p{
  margin: 1px;
}
</style>
</html>
